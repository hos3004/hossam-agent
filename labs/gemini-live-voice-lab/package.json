    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
