    "react-dom": "^19.2.6",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.3.0",
